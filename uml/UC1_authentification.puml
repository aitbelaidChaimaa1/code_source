@startuml UC1_Authentification
!theme mars
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam ArrowColor #555555
skinparam UsecaseBorderColor #2D6CDF
skinparam UsecaseBackgroundColor #EEF4FF
skinparam wrapWidth 200

left to right direction

title UC1 — Authentification — BrainQuest

actor "Étudiant"        as ETU
actor "Formateur"       as FOR
actor "Administrateur"  as ADM

rectangle "Système BrainQuest" {

  package "Accès" {
    usecase "S'inscrire"               as UC1
    usecase "Choisir module de départ" as UC2
    usecase "Se connecter"             as UC3
  }

  package "Validation" {
    usecase "Saisir email + mot de passe" as UC4
    usecase "Valider les données"         as UC5
  }

  package "Session" {
    usecase "Générer token JWT"       as UC6
    usecase "Accéder au Hub Central"  as UC7
  }

}

ETU --> UC1
ETU --> UC3
FOR --> UC3
ADM --> UC3

UC1 .> UC2 : <<include>>
UC1 .> UC4 : <<include>>
UC3 .> UC4 : <<include>>
UC4 .> UC5 : <<include>>
UC3 .> UC6 : <<include>>
UC6 .> UC7 : <<include>>

@enduml
