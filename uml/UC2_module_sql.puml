@startuml UC2_Module_SQL
!theme mars
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam ArrowColor #555555
skinparam UsecaseBorderColor #2D6CDF
skinparam UsecaseBackgroundColor #EEF4FF
skinparam wrapWidth 200

left to right direction

title UC2 — Module SQL — BrainQuest

actor "Étudiant"    as ETU
actor "IA (Claude)" as IA #technology

rectangle "Module SQL" {

  package "Navigation" {
    usecase "Accéder à la carte monde SQL"  as UC1
    usecase "Passer test de positionnement" as UC2
    usecase "Choisir une zone (1 à 5)"      as UC3
    usecase "Voir le schéma des tables"     as UC4
  }

  package "Mission" {
    usecase "Lancer une mission SQL"      as UC5
    usecase "Lire le scénario de mission" as UC6
    usecase "Écrire une requête SQL"      as UC7
    usecase "Exécuter la requête"         as UC8
    usecase "Voir le résultat"            as UC9
    usecase "Valider la mission"          as UC10
  }

  package "Aide & Récompense" {
    usecase "Demander un indice (niveau 1/2/3)" as UC11
    usecase "Gagner des XP"                     as UC12
  }

  package "Intelligence Artificielle" {
    usecase "Générer une mission via IA"     as UC13
    usecase "Fournir un indice pédagogique"  as UC14
  }

}

ETU --> UC1
ETU --> UC2
ETU --> UC3
ETU --> UC4
ETU --> UC7
ETU --> UC11

IA --> UC13
IA --> UC14

UC3  .> UC5  : <<include>>
UC5  .> UC6  : <<include>>
UC5  .> UC13 : <<include>>
UC4  .> UC7  : <<extend>>
UC7  .> UC8  : <<include>>
UC8  .> UC9  : <<include>>
UC9  .> UC10 : <<extend>>
UC10 .> UC12 : <<include>>
UC8  .> UC11 : <<extend>>
UC11 .> UC14 : <<include>>

@enduml
